@page
@model RagChatbot.RazorPages.Pages.Document.ViewDocModel
@{
    var doc = Model.Document;
    ViewData["Title"] = doc.FileName;
    var ext = System.IO.Path.GetExtension(doc.FileName).ToLower();
    var chunks = Model.Chunks;
    var total = chunks.Count;
    var words = Model.TotalWords;
    var avgWords = total > 0 ? words / total : 0;
}

<div class="breadcrumb-app">
    <a asp-page="/Subject/Index"><i class="bi bi-book me-1"></i>Môn học</a>
    <span class="sep"><i class="bi bi-chevron-right" style="font-size:10px"></i></span>
    <a asp-page="Index" asp-route-subjectId="@doc.SubjectId">Tài liệu</a>
    <span class="sep"><i class="bi bi-chevron-right" style="font-size:10px"></i></span>
    <span class="current">@doc.FileName</span>
</div>

<div class="fade-in-up" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;gap:12px;flex-wrap:wrap">
    <div style="display:flex;align-items:center;gap:10px">
        <div class="file-icon @(ext == ".pdf" ? "pdf" : ext == ".txt" ? "txt" : ext == ".docx" ? "docx" : "other")" style="width:40px;height:40px;font-size:20px">
            <i class="bi @(ext == ".pdf" ? "bi-file-earmark-pdf" : ext == ".txt" ? "bi-file-earmark-text" : "bi-file-earmark")"></i>
        </div>
        <div>
            <div style="font-size:16px;font-weight:700;color:var(--text-1)">@doc.FileName</div>
            <div style="font-size:12px;color:var(--text-3)">Tải lên lúc @doc.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
        </div>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
        @if (User.IsInRole("Admin") || User.IsInRole("Lecturer"))
        {
            <form method="post" asp-page-handler="GenerateSummary" asp-route-id="@doc.Id" style="margin:0">
                <button type="submit" class="btn-app btn-success-app btn-sm-app">
                    <i class="bi bi-stars"></i> Tạo tóm tắt
                </button>
            </form>
            <a asp-page="/Quiz/Generate" asp-route-documentId="@doc.Id" class="btn-app btn-sm-app" style="background:#8b5cf6;color:#fff;border-color:#8b5cf6">
                <i class="bi bi-magic"></i> Tạo Quiz AI
            </a>
        }
        <a asp-page="Index" asp-route-subjectId="@doc.SubjectId" class="btn-app btn-ghost btn-sm-app">
            <i class="bi bi-arrow-left"></i> Danh sách
        </a>
        <a asp-page="Download" asp-route-id="@doc.Id" class="btn-app btn-primary-app btn-sm-app">
            <i class="bi bi-download"></i> Tải về
        </a>
    </div>
</div>

<div class="vd-tabs fade-in-up">
    <button class="vd-tab active" onclick="switchTab('viewer', this)">
        <i class="bi bi-eye"></i> Xem tài liệu
    </button>
    <button class="vd-tab" onclick="switchTab('summary', this)">
        <i class="bi bi-journal-check"></i> Tóm tắt AI
    </button>
    <button class="vd-tab" onclick="switchTab('chunks', this)">
        <i class="bi bi-grid-3x3-gap"></i> Chunk <span class="chunk-count-badge">@total</span>
    </button>
</div>

<div id="tab-viewer" class="vd-pane fade-in-up">
    <div class="card" style="overflow:hidden;height:calc(100vh - var(--topbar-height) - 210px)">
        @if (ext == ".pdf")
        {
            <iframe src="@doc.FilePath" style="width:100%;height:100%;border:none;display:block"></iframe>
        }
        else if (ext == ".txt")
        {
            <div style="height:100%;overflow-y:auto;background:#1E1E2E;padding:24px">
                <pre style="margin:0;white-space:pre-wrap;font-family:'Consolas','Courier New',monospace;font-size:14px;line-height:1.7;color:#CDD6F4">@Model.FileContent</pre>
            </div>
        }
        else
        {
            <div class="empty-state" style="height:100%">
                <span class="empty-icon"><i class="bi bi-file-earmark-x"></i></span>
                <div class="empty-title">Trình duyệt không hỗ trợ xem định dạng này</div>
                <div class="empty-sub">Vui lòng tải file về để xem nội dung.</div>
            </div>
        }
    </div>
</div>

<div id="tab-summary" class="vd-pane d-none">
    @if (Model.Summary == null)
    {
        <div class="table-card fade-in-up">
            <div class="empty-state">
                <span class="empty-icon"><i class="bi bi-journal-check"></i></span>
                <div class="empty-title">Chưa có tóm tắt AI</div>
                <div class="empty-sub">Sau khi tài liệu xử lý xong, hệ thống sẽ tự tạo tóm tắt. Giảng viên cũng có thể tạo lại thủ công.</div>
            </div>
        </div>
    }
    else
    {
        <div class="summary-grid fade-in-up">
            <section class="summary-panel wide">
                <h3><i class="bi bi-card-text"></i> Tóm tắt</h3>
                <div class="summary-text">@Model.Summary.Summary</div>
            </section>
            <section class="summary-panel">
                <h3><i class="bi bi-list-check"></i> Ý chính</h3>
                <div class="summary-text">@Model.Summary.KeyPoints</div>
            </section>
            <section class="summary-panel">
                <h3><i class="bi bi-bullseye"></i> Mục tiêu bài học</h3>
                <div class="summary-text">@Model.Summary.LearningObjectives</div>
            </section>
            <section class="summary-panel wide">
                <h3><i class="bi bi-tags"></i> Thuật ngữ quan trọng</h3>
                <div class="summary-text">@Model.Summary.ImportantTerms</div>
            </section>
        </div>
    }
</div>

<div id="tab-chunks" class="vd-pane d-none">
    @if (total == 0)
    {
        <div class="table-card fade-in-up">
            <div class="empty-state">
                <span class="empty-icon"><i class="bi bi-grid-3x3-gap"></i></span>
                <div class="empty-title">Chưa có chunk nào</div>
                <div class="empty-sub">Tài liệu này chưa được AI xử lý hoặc xử lý thất bại. Trạng thái hiện tại: <strong>@doc.Status</strong></div>
            </div>
        </div>
    }
    else
    {
        <div class="chunk-stats-row fade-in-up">
            <div class="chunk-stat-card"><div class="csc-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div><div><div class="csc-value">@total</div><div class="csc-label">Tổng số chunk</div></div></div>
            <div class="chunk-stat-card"><div class="csc-icon"><i class="bi bi-file-word"></i></div><div><div class="csc-value">@words.ToString("N0")</div><div class="csc-label">Tổng số từ</div></div></div>
            <div class="chunk-stat-card"><div class="csc-icon"><i class="bi bi-calculator"></i></div><div><div class="csc-value">~@avgWords</div><div class="csc-label">Từ trung bình / chunk</div></div></div>
            <div class="chunk-stat-card"><div class="csc-icon"><i class="bi bi-cpu"></i></div><div><div class="csc-value">768</div><div class="csc-label">Chiều vector embedding</div></div></div>
        </div>

        <div class="chunk-list fade-in-up">
            @foreach (var chunk in chunks)
            {
                <div class="chunk-card" id="chunk-@chunk.Index">
                    <div class="chunk-card-header" onclick="toggleChunk(@chunk.Index)">
                        <div style="display:flex;align-items:center;gap:12px">
                            <span class="chunk-index-badge">#@chunk.Index</span>
                            <div>
                                <div style="font-size:13px;font-weight:600;color:var(--text-1)">Chunk @chunk.Index / @total</div>
                                <div style="font-size:12px;color:var(--text-3)">@chunk.WordCount từ</div>
                            </div>
                        </div>
                        <i class="bi bi-chevron-down chunk-chevron" id="chev-@chunk.Index"></i>
                    </div>
                    <div class="chunk-card-body d-none" id="body-@chunk.Index">
                        <div class="chunk-preview">@chunk.TextContent</div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<style>
.vd-tabs{display:flex;gap:4px;background:var(--surface-2);border-radius:12px;padding:4px;margin-bottom:16px;width:fit-content;flex-wrap:wrap}
.vd-tab{display:flex;align-items:center;gap:6px;padding:8px 18px;border-radius:9px;border:none;background:transparent;color:var(--text-2);font-size:13px;font-weight:600;cursor:pointer}
.vd-tab.active{background:var(--primary);color:#fff;box-shadow:0 2px 8px rgba(99,102,241,.35)}
.chunk-count-badge{background:rgba(255,255,255,.25);font-size:11px;font-weight:800;padding:1px 7px;border-radius:20px}
.summary-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
.summary-panel{background:#fff;border:1px solid var(--border);border-radius:8px;padding:18px;box-shadow:var(--shadow)}
.summary-panel.wide{grid-column:1 / -1}
.summary-panel h3{display:flex;align-items:center;gap:8px;font-size:15px;font-weight:800;color:var(--text-1);margin:0 0 10px}
.summary-text{white-space:pre-wrap;color:var(--text-2);line-height:1.7;font-size:14px}
.chunk-stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:12px;margin-bottom:16px}
.chunk-stat-card{background:var(--surface-2);border:1px solid var(--border);border-radius:8px;padding:16px;display:flex;align-items:center;gap:12px}
.csc-icon{width:40px;height:40px;border-radius:8px;background:rgba(99,102,241,.12);color:var(--primary);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.csc-value{font-size:22px;font-weight:800;color:var(--text-1);line-height:1.1}
.csc-label{font-size:11px;color:var(--text-3);margin-top:2px}
.chunk-list{display:flex;flex-direction:column;gap:8px}
.chunk-card{background:var(--surface-2);border:1px solid var(--border);border-radius:8px;overflow:hidden}
.chunk-card-header{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;cursor:pointer;user-select:none}
.chunk-index-badge{width:36px;height:36px;border-radius:8px;background:linear-gradient(135deg,var(--primary),var(--secondary));color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;flex-shrink:0}
.chunk-chevron{color:var(--text-3);transition:transform .25s}
.chunk-chevron.open{transform:rotate(180deg)}
.chunk-card-body{padding:0 16px 16px}
.chunk-preview{font-size:13px;line-height:1.75;color:var(--text-2);background:var(--surface-3);border-radius:8px;padding:12px 14px;white-space:pre-wrap;word-break:break-word}
@@media (max-width: 800px){.summary-grid{grid-template-columns:1fr}}
</style>
<script>
function switchTab(name, btn) {
    document.querySelectorAll('.vd-pane').forEach(p => p.classList.add('d-none'));
    document.querySelectorAll('.vd-tab').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.remove('d-none');
    btn.classList.add('active');
}

function toggleChunk(index) {
    document.getElementById('body-' + index).classList.toggle('d-none');
    document.getElementById('chev-' + index).classList.toggle('open');
}
</script>
}
