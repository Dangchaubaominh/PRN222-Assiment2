@page
@model RagChatbot.RazorPages.Pages.Quiz.IndexModel
@{
    ViewData["Title"] = "Quiz — " + Model.Subject?.Code;
}

<div class="breadcrumb-app">
    <a asp-page="/Subject/Index"><i class="bi bi-book me-1"></i>Môn học</a>
    <span class="sep"><i class="bi bi-chevron-right" style="font-size:10px"></i></span>
    <span class="current">Quiz — @Model.Subject?.Code</span>
</div>

<div class="page-header fade-in-up">
    <div class="page-header-left">
        <h1>Quiz từ tài liệu</h1>
        <p><span class="subject-code-badge">@Model.Subject?.Code</span> &nbsp;@Model.Subject?.Name</p>
    </div>
    <a asp-page="/Subject/Index" class="btn-app btn-ghost">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

@if (User.IsInRole("Admin") || User.IsInRole("Lecturer"))
{
    <div class="table-card fade-in-up" style="padding:18px;margin-bottom:16px">
        <form method="post" asp-page-handler="Generate" asp-route-subjectId="@Model.SubjectId" class="quiz-generate-form">
            <select name="documentId" class="form-control-app">
                <option value="">Tạo từ tất cả tài liệu đã học</option>
                @foreach (var doc in Model.Documents)
                {
                    <option value="@doc.Id">@doc.FileName</option>
                }
            </select>
            <input type="number" name="questionCount" min="3" max="10" value="5" class="form-control-app" style="max-width:120px" />
            <button type="submit" class="btn-app btn-primary-app">
                <i class="bi bi-stars"></i> Tạo quiz
            </button>
        </form>
    </div>
}

@if (!Model.Quizzes.Any())
{
    <div class="table-card">
        <div class="empty-state">
            <span class="empty-icon"><i class="bi bi-ui-checks"></i></span>
            <div class="empty-title">Chưa có quiz nào</div>
            <div class="empty-sub">Giảng viên có thể tạo quiz tự động từ tài liệu đã upload.</div>
        </div>
    </div>
}
else
{
    <div class="quiz-list fade-in-up">
        @foreach (var quiz in Model.Quizzes)
        {
            bool hasAttempt = Model.LatestAttempts.TryGetValue(quiz.Id, out var attempt);
            <section class="quiz-card">
                <div class="quiz-card-head">
                    <div>
                        <h2>@quiz.Title</h2>
                        <div class="quiz-meta">@quiz.Questions.Count câu hỏi · Tạo lúc @quiz.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                        @if (hasAttempt)
                        {
                            <div class="quiz-retake-note">
                                Lần gần nhất: lần @attempt!.AttemptNumber, đạt @attempt.Score/@attempt.TotalQuestions câu đúng.
                                Bạn có thể làm lại bài quiz nếu chưa hài lòng với kết quả.
                            </div>
                        }
                    </div>
                    @if (hasAttempt)
                    {
                        <span class="quiz-score">@attempt!.Score/@attempt.TotalQuestions</span>
                    }
                </div>

                <form method="post" asp-page-handler="Submit" asp-route-subjectId="@Model.SubjectId" asp-route-quizId="@quiz.Id">
                    <div class="quiz-question-list">
                        @for (int i = 0; i < quiz.Questions.Count; i++)
                        {
                            var q = quiz.Questions[i];
                            <div class="quiz-question">
                                <div class="quiz-question-title">@($"{i + 1}. {q.QuestionText}")</div>
                                <div class="quiz-options">
                                    @foreach (var option in q.Options)
                                    {
                                        var answer = option.Length > 0 ? option.Substring(0, 1).ToUpperInvariant() : "";
                                        <label class="quiz-option">
                                            <input type="radio" name="answers[@q.Id]" value="@answer" required />
                                            <span>@option</span>
                                        </label>
                                    }
                                </div>
                                @if (hasAttempt)
                                {
                                    <div class="quiz-explain">
                                        Đáp án đúng: <strong>@q.CorrectAnswer</strong><br />
                                        @q.Explanation
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <button type="submit" class="btn-app btn-success-app">
                        <i class="bi bi-check2-circle"></i> @(hasAttempt ? "Làm lại bài quiz" : "Nộp bài")
                    </button>
                </form>
            </section>
        }
    </div>
}

@section Scripts {
<style>
.quiz-generate-form{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.quiz-generate-form .form-control-app{min-width:240px}
.quiz-list{display:grid;gap:16px}
.quiz-card{background:#fff;border:1px solid var(--border);border-radius:8px;padding:18px;box-shadow:var(--shadow)}
.quiz-card-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;margin-bottom:14px}
.quiz-card h2{font-size:17px;font-weight:800;color:var(--text-1);margin:0}
.quiz-meta{font-size:12px;color:var(--text-3);margin-top:4px}
.quiz-retake-note{margin-top:8px;color:var(--text-2);font-size:13px;line-height:1.5}
.quiz-score{display:inline-flex;align-items:center;justify-content:center;min-width:62px;height:34px;border-radius:8px;background:rgba(16,185,129,.12);color:#059669;font-weight:800;flex-shrink:0}
.quiz-question-list{display:grid;gap:12px;margin-bottom:14px}
.quiz-question{border:1px solid var(--border);border-radius:8px;padding:14px;background:var(--surface-2)}
.quiz-question-title{font-weight:800;color:var(--text-1);margin-bottom:10px}
.quiz-options{display:grid;gap:8px}
.quiz-option{display:flex;align-items:flex-start;gap:8px;padding:9px 10px;border:1px solid var(--border);border-radius:8px;background:#fff;cursor:pointer}
.quiz-option span{line-height:1.5}
.quiz-explain{margin-top:10px;padding:10px;border-left:3px solid var(--primary);background:rgba(99,102,241,.07);border-radius:8px;color:var(--text-2);font-size:13px;line-height:1.55}
</style>
}
