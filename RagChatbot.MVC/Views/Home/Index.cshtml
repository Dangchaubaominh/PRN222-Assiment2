@{
    ViewData["Title"] = "Tổng quan";
    var fullName = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
                ?? User.Identity?.Name ?? "";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
}

<div class="welcome-banner fade-in-up">
    <h1 class="welcome-title">Xin chào, @fullName! 👋</h1>
    <p class="welcome-sub">Chào mừng bạn quay lại EduChatbot — nền tảng học tập thông minh được hỗ trợ bởi AI.</p>
</div>

<div class="row g-4 mb-4 fade-in-up">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon indigo"><i class="bi bi-book"></i></div>
            <div class="stat-value">Môn học</div>
            <div class="stat-label">Quản lý môn học & tài liệu</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-robot"></i></div>
            <div class="stat-value">AI Chat</div>
            <div class="stat-label">Trợ lý RAG thông minh</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon amber"><i class="bi bi-file-earmark-text"></i></div>
            <div class="stat-value">Tài liệu</div>
            <div class="stat-label">PDF, TXT và nhiều hơn nữa</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon cyan"><i class="bi bi-search"></i></div>
            <div class="stat-value">RAG</div>
            <div class="stat-label">Tìm kiếm ngữ nghĩa tiên tiến</div>
        </div>
    </div>
</div>

<div class="row g-4 fade-in-up">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header-custom">
                <h5><i class="bi bi-lightning-charge text-warning me-2"></i>Bắt đầu nhanh</h5>
            </div>
            <div style="padding: 20px 24px; display:flex; flex-direction:column; gap:10px;">
                <a asp-controller="Subject" asp-action="Index" class="btn-app btn-primary-app w-100" style="justify-content:center">
                    <i class="bi bi-book"></i> Vào danh sách Môn học
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="User" asp-action="Index" class="btn-app btn-ghost w-100" style="justify-content:center">
                        <i class="bi bi-people"></i> Quản lý Tài khoản
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header-custom">
                <h5><i class="bi bi-info-circle text-primary me-2"></i>Về hệ thống</h5>
            </div>
            <div style="padding: 20px 24px;">
                <div style="display:flex;flex-direction:column;gap:12px;">
                    <div style="display:flex;align-items:center;gap:10px;font-size:13.5px;">
                        <span style="width:28px;height:28px;background:#EEF2FF;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#6366F1;font-size:14px;flex-shrink:0"><i class="bi bi-cpu"></i></span>
                        <span>Sử dụng <strong>Gemini AI</strong> với công nghệ RAG</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;font-size:13.5px;">
                        <span style="width:28px;height:28px;background:#D1FAE5;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#10B981;font-size:14px;flex-shrink:0"><i class="bi bi-shield-check"></i></span>
                        <span>Phân quyền <strong>3 cấp</strong>: Admin, Giảng viên, Sinh viên</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;font-size:13.5px;">
                        <span style="width:28px;height:28px;background:#CFFAFE;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#06B6D4;font-size:14px;flex-shrink:0"><i class="bi bi-database"></i></span>
                        <span>Lưu trữ vector trên <strong>PostgreSQL + pgvector</strong></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
