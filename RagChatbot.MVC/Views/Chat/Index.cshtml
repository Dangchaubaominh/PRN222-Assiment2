@{
    ViewData["Title"] = "Chat AI";
}

<div class="chat-wrapper fade-in-up">
    <!-- Header -->
    <div class="chat-header">
        <div class="chat-avatar">🤖</div>
        <div>
            <div class="chat-title">Trợ lý AI — RAG Chatbot</div>
            <div class="chat-subtitle">Đã sẵn sàng trả lời dựa trên tài liệu môn học</div>
        </div>
        <div style="margin-left:auto">
            <a href="@Url.Action("Index", "Subject")" class="btn-app btn-sm-app"
               style="background:rgba(255,255,255,.15);color:#fff;gap:4px">
                <i class="bi bi-arrow-left"></i> Trở về
            </a>
        </div>
    </div>

    <!-- Messages -->
    <div class="chat-messages" id="chatMessages">
        <div class="msg-row">
            <div class="msg-avatar ai"><i class="bi bi-robot"></i></div>
            <div class="msg-bubble ai">
                <strong>Xin chào! 👋</strong><br/>
                Tôi là trợ lý AI đã được học từ tài liệu của môn học này.
                Bạn có thể hỏi tôi bất cứ điều gì liên quan đến nội dung tài liệu.
            </div>
        </div>
    </div>

    <!-- Input -->
    <div class="chat-input-area">
        <input type="hidden" id="SubjectId" value="@ViewBag.SubjectId" />
        <input type="text" id="userInput" class="chat-input"
               placeholder="Nhập câu hỏi của bạn..." autocomplete="off" />
        <button class="chat-send-btn" id="sendBtn" onclick="sendMessage()">
            <i class="bi bi-send-fill" style="font-size:16px"></i>
        </button>
    </div>
</div>

@section Scripts {
<script>
    const messagesEl = document.getElementById('chatMessages');
    const inputEl    = document.getElementById('userInput');
    const sendBtn    = document.getElementById('sendBtn');

    inputEl.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    });

    function sendMessage() {
        const text = inputEl.value.trim();
        if (!text) return;

        appendMsg(text, 'user');
        inputEl.value = '';
        sendBtn.disabled = true;

        const loadingId = 'loading-' + Date.now();
        appendMsg('Đang tìm kiếm trong tài liệu<span class="typing-dots"></span>', 'ai', loadingId);

        const subjectId = document.getElementById('SubjectId').value;
        const fd = new FormData();
        fd.append('subjectId', subjectId);
        fd.append('userMessage', text);

        fetch('@Url.Action("SendMessage", "Chat")', { method: 'POST', body: fd })
            .then(r => r.json())
            .then(data => {
                document.getElementById(loadingId)?.remove();
                appendMsg(data.reply, 'ai');
            })
            .catch(() => {
                document.getElementById(loadingId)?.remove();
                appendMsg('❌ Lỗi kết nối đến máy chủ. Vui lòng thử lại.', 'ai');
            })
            .finally(() => { sendBtn.disabled = false; inputEl.focus(); });
    }

    function appendMsg(text, type, id = null) {
        const row = document.createElement('div');
        row.className = 'msg-row ' + type;
        if (id) row.id = id;

        const avatar = document.createElement('div');
        avatar.className = 'msg-avatar ' + type;
        avatar.innerHTML = type === 'ai'
            ? '<i class="bi bi-robot"></i>'
            : '<i class="bi bi-person-fill"></i>';

        const bubble = document.createElement('div');
        bubble.className = 'msg-bubble ' + type;
        bubble.innerHTML = '<span style="white-space:pre-wrap">' + text + '</span>';

        row.appendChild(avatar);
        row.appendChild(bubble);
        messagesEl.appendChild(row);
        messagesEl.scrollTop = messagesEl.scrollHeight;
    }
</script>
}
